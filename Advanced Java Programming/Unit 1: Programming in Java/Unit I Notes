        }

        // ArrayIndexOutOfBoundsException
        try {
            int[] arr = new int[3];
            System.out.println(arr[5]);
        } catch (ArrayIndexOutOfBoundsException e) {
            System.out.println("ArrayIndexOutOfBoundsException: " + e.getMessage());
        }

        // ArrayStoreException
        try {
            Object[] objs = new String[2];
            objs[0] = 10; // wrong type
        } catch (ArrayStoreException e) {
            System.out.println("ArrayStoreException: " + e.getMessage());
        }

        // ClassCastException
        try {
            Object obj = new Integer(10);
            String s = (String) obj;
        } catch (ClassCastException e) {
            System.out.println("ClassCastException: " + e.getMessage());
        }

        // StringIndexOutOfBoundsException
        try {
            String s = "Hello";
            System.out.println(s.charAt(10));
        } catch (StringIndexOutOfBoundsException e) {
            System.out.println("StringIndexOutOfBoundsException: " + e.getMessage());
        }

        // FileNotFoundException
        try {
            FileReader fr = new FileReader("nofile.txt");
        } catch (FileNotFoundException e) {
            System.out.println("FileNotFoundException: " + e.getMessage());
        }

        // IOException
        try {
            FileReader fr = new FileReader("nofile.txt");
            fr.read();
        } catch (IOException e) {
            System.out.println("IOException: " + e.getMessage());
        }

        // InterruptedException
        try {
            Thread.sleep(10); // usually won't throw, but must handle
        } catch (InterruptedException e) {
            System.out.println("InterruptedException: " + e.getMessage());
        }

        // IllegalArgumentException
        try {
            Thread t = new Thread();
            t.setPriority(100); // invalid
        } catch (IllegalArgumentException e) {
            System.out.println("IllegalArgumentException: " + e.getMessage());
        }

        // IllegalStateException
        try {
            Thread t = new Thread();
            t.start();
            t.start(); // starting again
        } catch (IllegalThreadStateException e) { // subclass of IllegalStateException
            System.out.println("IllegalStateException: " + e.getMessage());
        }

        // UnsupportedOperationException
        try {
            java.util.List<String> list = java.util.Collections.unmodifiableList(new java.util.ArrayList<>());
            list.add("Hello");
        } catch (UnsupportedOperationException e) {
            System.out.println("UnsupportedOperationException: " + e.getMessage());
        }
    }
}

