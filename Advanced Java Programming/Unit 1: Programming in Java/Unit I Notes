e) Buffered Writer
BufferedWriter is used to wrap another Writer (like FileWriter) and buffer the data, making writes more efficient.

import java.io.BufferedWriter;
import java.io.FileWriter;
import java.io.IOException;

public class BufferedWriterExample {
    public static void main(String[] args) {
        String fileName = "output.txt";

        // Using try-with-resources to automatically close the writer
        try (BufferedWriter bw = new BufferedWriter(new FileWriter(fileName))) {

            // Write text lines
            bw.write("Hello, world!");
            bw.newLine();  // adds a newline
            bw.write("This is a BufferedWriter example.");
            bw.newLine();
            bw.write("It writes text efficiently to a file.");

            System.out.println("Data written successfully!");

        } catch (IOException e) {
            System.out.println("Error writing to file: " + e.getMessage());
        }
    }
}


